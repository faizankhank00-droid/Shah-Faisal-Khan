@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
    scroll-behavior:smooth;
}

body{
    background:#f5f9ff;
    color:#1f2937;
    line-height:1.7;
}

/* Navigation */
header{
    position:fixed;
    top:0;
    width:100%;
    background:#ffffff;
    box-shadow:0 2px 15px rgba(0,0,0,.08);
    z-index:1000;
}

nav{
    max-width:1200px;
    margin:auto;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 30px;
}

nav h2{
    color:#0b63ce;
    font-weight:700;
}

nav ul{
    display:flex;
    gap:30px;
    list-style:none;
}

nav a{
    text-decoration:none;
    color:#333;
    font-weight:500;
    transition:.3s;
}

nav a:hover{
    color:#0b63ce;
}

/* Hero */
.hero{
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:space-between;
    max-width:1200px;
    margin:auto;
    padding:120px 30px 60px;
    gap:40px;
}

.hero-text{
    flex:1;
}

.hero h1{
    font-size:55px;
    margin-bottom:15px;
}

.hero span{
    color:#0b63ce;
}

.hero h3{
    color:#555;
    margin-bottom:20px;
}

.hero p{
    font-size:18px;
    margin-bottom:35px;
}

.btn,.btn2{
    display:inline-block;
    padding:14px 28px;
    border-radius:40px;
    text-decoration:none;
    margin-right:15px;
    transition:.3s;
}

.btn{
    background:#0b63ce;
    color:white;
}

.btn:hover{
    background:#004db3;
}

.btn2{
    border:2px solid #0b63ce;
    color:#0b63ce;
}

.btn2:hover{
    background:#0b63ce;
    color:white;
}

/* Profile Image */
.hero-image img{
    width:350px;
    height:350px;
    border-radius:50%;
    object-fit:cover;
    border:8px solid white;
    box-shadow:0 20px 45px rgba(0,0,0,.15);
}

/* Sections */
section{
    padding:90px 30px;
    max-width:1200px;
    margin:auto;
}

section h2{
    text-align:center;
    font-size:36px;
    margin-bottom:40px;
    color:#0b63ce;
}

/* Cards */
.card,
.timeline-item{
    background:white;
    border-radius:18px;
    padding:30px;
    margin-bottom:25px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

/* Skills */
.skill-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:20px;
}

.skill-grid div{
    background:white;
    padding:20px;
    text-align:center;
    border-radius:15px;
    font-weight:600;
    box-shadow:0 8px 25px rgba(0,0,0,.08);
    transition:.3s;
}

.skill-grid div:hover{
    transform:translateY(-8px);
    background:#0b63ce;
    color:white;
}

/* Achievement Cards */
.achievement-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:20px;
}

.achievement-card{
    background:white;
    border-radius:15px;
    text-align:center;
    padding:25px;
    box-shadow:0 8px 25px rgba(0,0,0,.08);
}

.achievement-card h3{
    font-size:38px;
    color:#0b63ce;
}

/* Awards */
.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:25px;
}

.gallery img{
    width:100%;
    border-radius:15px;
    box-shadow:0 12px 25px rgba(0,0,0,.12);
    transition:.4s;
}

.gallery img:hover{
    transform:scale(1.05);
}

/* Contact */
#contact{
    text-align:center;
}

#contact p{
    margin:15px 0;
    font-size:18px;
}

#contact a{
    color:#0b63ce;
    text-decoration:none;
}

/* Footer */
footer{
    background:#0b63ce;
    color:white;
    text-align:center;
    padding:20px;
}

/* Mobile */
@media(max-width:768px){

nav{
flex-direction:column;
}

nav ul{
margin-top:15px;
flex-wrap:wrap;
justify-content:center;
}

.hero{
flex-direction:column-reverse;
text-align:center;
}

.hero h1{
font-size:38px;
}

.hero-image img{
width:250px;
height:250px;
}

}

// Smooth fade-in animation
const sections = document.querySelectorAll("section");

const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.style.opacity = "1";
      entry.target.style.transform = "translateY(0)";
    }
  });
}, { threshold: 0.15 });

sections.forEach((section) => {
  section.style.opacity = "0";
  section.style.transform = "translateY(40px)";
  section.style.transition = "all 0.8s ease";
  observer.observe(section);
});

// Active navigation
const navLinks = document.querySelectorAll("nav ul li a");

window.addEventListener("scroll", () => {
  let current = "";

  sections.forEach((section) => {
    const sectionTop = section.offsetTop - 120;
    if (pageYOffset >= sectionTop) {
      current = section.getAttribute("id");
    }
  });

  navLinks.forEach((link) => {
    link.classList.remove("active");
    if (link.getAttribute("href") === "#" + current) {
      link.classList.add("active");
    }
  });
});

